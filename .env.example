# ─────────────────────────────────────────
#  ServiceSync Pro — Backend Environment
#  Copy this file to .env and fill values
# ─────────────────────────────────────────

# ── Server ────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=super_secret_jwt_key_change_in_prod

# ── Frontend origin (CORS) ────────────────
# Local:
FRONTEND_URL=http://localhost:8081
# Production (comma-separated for multiple):
# FRONTEND_URL=https://yoursite.com,https://www.yoursite.com


# ══════════════════════════════════════════
#  DATABASE — pick one block below
# ══════════════════════════════════════════

# ── LOCAL (PostgreSQL on your machine) ────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=123456
DB_NAME=servicesync

# ── LIVE / PRODUCTION ─────────────────────
# Option A: individual vars (Railway, Render, VPS)
# DB_HOST=your-db-host.railway.app
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=your_strong_password_here
# DB_NAME=servicesync

# Option B: single connection URL (Supabase, Neon, PlanetScale-pg)
# Uncomment and set DB_URL, then update app.module.ts to use it
# DB_URL=postgresql://user:password@host:5432/dbname?sslmode=require